.registers {
    A, B <- 3x3 builtin (90, 90)
}

.macro floor-div-2 {
   ($IN:reg $OUT:reg) => {
        loop {
            solved-goto $IN break
            dec $IN
            solved-goto $IN break
            dec $IN
            inc $OUT
        }
    }
}

input "First number:" A
input "Second number:" B

while not-solved B {
    inc A
    dec B
    solved-goto A overflow
}

floor-div-2 A B
halt "The average is" B

overflow:

while not-solved B {
    inc A
    dec B
}

floor-div-2 A B
add B 45
halt "The average is" B
