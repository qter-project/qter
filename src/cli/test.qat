#!/usr/bin/env -S cargo run -- interpret
.registers {
    1B, A ← 3x3 builtin (24, 210)
}

.define MOD 13

input "Number to modulus:" A

loop:

print "A is now" A
add 1B $MOD

while not-solved A {
    solved-goto 1B loop
    dec A
    dec 1B
}

while not-solved 1B%8 {
    dec A
    dec 1B
}

add A $MOD

halt "The modulus is" A
